{
  "name": "whiteblue-hardware-test-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev.ts",
    "dev:app": "tsx watch src/server.ts",
    "dev:payment": "tsx watch src/paymentServer.ts",
    "build": "tsc && npm run build:qa-report-viewer",
    "build:ci": "node ./node_modules/typescript/bin/tsc",
    "build:qa-report-viewer": "powershell -ExecutionPolicy Bypass -File scripts/packageQaReportViewer.ps1",
    "start": "node dist/dev.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load/whiteblue-api.k6.js",
    "test:load:smoke": "k6 run --vus 1 --duration 10s tests/load/whiteblue-api.k6.js",
    "test:load:docker": "powershell -ExecutionPolicy Bypass -File scripts/runK6Docker.ps1",
    "test:load:docker:smoke": "powershell -ExecutionPolicy Bypass -File scripts/runK6Docker.ps1 -Smoke",
    "test:all": "tsx scripts/runParallelFailFastTests.ts",
    "test:report": "tsx scripts/generateTestReport.ts",
    "prerequisites:check": "powershell -ExecutionPolicy Bypass -File scripts/checkAndInstallPrerequisites.ps1"
  },
  "dependencies": {
    "chai": "^4.5.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "pg": "^8.21.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.5.0",
    "@playwright/test": "^1.45.3",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0",
    "xlsx": "^0.18.5"
  }
}
