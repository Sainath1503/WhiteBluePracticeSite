{
  "consumer": {
    "name": "WhiteBlue Web"
  },
  "interactions": [
    {
      "description": "a request for the hardware catalog",
      "request": {
        "method": "GET",
        "path": "/menu"
      },
      "response": {
        "body": {
          "items": [
            {
              "category": "component",
              "description": "8-core desktop CPU for fast gaming and workstation builds",
              "id": "cpu-ryzen-7",
              "name": "Ryzen 7 Processor",
              "price": 299
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].category": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "component|accessory|peripheral"
                }
              ]
            },
            "$.items[*].description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^application\\/json(; ?charset=utf-8)?$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create a paid order",
      "request": {
        "body": {
          "cardId": "approved-card",
          "customerName": "WhiteBlue Demo User",
          "items": [
            {
              "menuItemId": "cpu-ryzen-7",
              "quantity": 1
            }
          ],
          "paymentToken": "gateway_paid_card:approved-card:test1"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^application\\/json(; ?charset=utf-8)?$"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/order"
      },
      "response": {
        "body": {
          "aiSuggestion": "AI pick: add a 32GB DDR5 Memory Kit to round out this build.",
          "customerName": "WhiteBlue Demo User",
          "items": [
            {
              "lineTotal": 299,
              "menuItemId": "cpu-ryzen-7",
              "name": "Ryzen 7 Processor",
              "quantity": 1,
              "unitPrice": 299
            }
          ],
          "orderId": "11111111-1111-4111-8111-111111111111",
          "paymentId": "pay_test123",
          "paymentStatus": "paid",
          "total": 299
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.aiSuggestion": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.customerName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orderId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.paymentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^pay_.+$"
                }
              ]
            }
          },
          "header": {
            "Content-Type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^application\\/json(; ?charset=utf-8)?$"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "WhiteBlue API"
  }
}